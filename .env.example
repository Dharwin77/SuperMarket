# Environment variables template
# Copy this file to .env.local and fill in your actual Firebase credentials

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Groq API configuration for chatbot
# For Vite frontend apps, prefer VITE_ prefixed variables.
VITE_GROQ_API_KEY=
# Optional fallback (non-Vite prefixed)
GROQ_API_KEY=
# Optional: override model
VITE_GROQ_MODEL=llama-3.3-70b-versatile
# Optional: vision model for product scanning
VITE_GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Optional: override API URL
VITE_GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# Public URL for WhatsApp bill links
# IMPORTANT: Set this to your production domain or ngrok tunnel URL
# NEVER use localhost for bill links shared via WhatsApp!
# Examples:
#   Production: VITE_PUBLIC_URL=https://smartretail.app
#   Development with ngrok: VITE_PUBLIC_URL=https://abcd1234.ngrok.io
#   Local testing (NOT for WhatsApp): VITE_PUBLIC_URL=http://localhost:8081
VITE_PUBLIC_URL=https://your-domain.com

# Backend API URL for payment requests.
# Use an HTTPS URL when the frontend is served over HTTPS to avoid mixed-content errors.
# Example: VITE_BACKEND_URL=https://abcd1234.ngrok-free.app
VITE_BACKEND_URL=https://your-backend-domain.com

# Razorpay — get your key from https://dashboard.razorpay.com
# Use rzp_test_... keys for development, rzp_live_... for production
VITE_RAZORPAY_KEY_ID=rzp_test_YourKeyIdHere
