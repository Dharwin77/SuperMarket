# Environment variables template
# Copy this file to .env.local and fill in your actual Firebase credentials

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Gemini AI API Key
# Get your free API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Public URL for WhatsApp bill links
# IMPORTANT: Set this to your production domain or ngrok tunnel URL
# NEVER use localhost for bill links shared via WhatsApp!
# Examples:
#   Production: VITE_PUBLIC_URL=https://smartretail.app
#   Development with ngrok: VITE_PUBLIC_URL=https://abcd1234.ngrok.io
#   Local testing (NOT for WhatsApp): VITE_PUBLIC_URL=http://localhost:8081
VITE_PUBLIC_URL=https://your-domain.com
